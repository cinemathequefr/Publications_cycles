          "typeEvenement": 13,
          "idFilm": 122509,
          "titre": "Deux jours, une nuit",
          "realisateurs": "Jean-Pierre Dardenne, Luc Dardenne",
          "annee": 2014,
          "pays": "Belgique-France-Italie",
          "generique": [
            "Marion Cotillard",
            "Fabrizio Rongione",
            "Pili Groyne"
          ],
          "textes": [
            {
              "typeTexte": 1000,
              "texte": "C'est le film des frères Dardenne le plus inventif du point de vue formel. C'est l'immense Marion Cotillard qui répète la même scène encore et encore, et nous bouleverse : elle supplie ses collègues de la sauver d'un plan de licenciement à l'usine qui lui ferait tout perdre. – É. L."
            }
          ]
        },
        {
          "idSeance": 217122,
          "ordre": 1,
          "dateHeure": "2026-06-03T19:00:00",
          "idSalle": [
            "GF",
            "Georges Franju"
          ],
          "dureeSeance": 90,
          "typeAssoc": 118,
          "idCategorie": 4171,
          "idEvenement": 36322,
          "typeEvenement": 13,
          "idFilm": 61393,
          "art": "La",
          "titre": "Vie de Jésus",
          "realisateurs": "Bruno Dumont",
          "annee": 1997,
          "pays": "France",
          "duree": 96,
          "version": "",
          "format": "35 mm",
          "generique": [
            "David Douche",
            "Marjorie Cottreel",
            "Geneviève Cottreel"
          ],
          "textes": [
            {
              "typeTexte": 1000,
              "texte": "C'est une histoire d'amour, et une histoire de la haine. C'est un garçon qui aime une fille dans un village du Nord, et c'est un groupe de garçons qui haïssent l'Autre, l'étranger, à travers le visage de Kader, l'Arabe du village. — É. L."
            }
          ]
        },
        {
          "idSeance": 217126,
          "ordre": 1,
          "dateHeure": "2026-06-15T19:00:00",
          "idSalle": [
            "GF",
            "Georges Franju"
          ],
          "dureeSeance": 135,
          "typeAssoc": 118,
          "idCategorie": 4171,
          "idEvenement": 36324,
          "typeEvenement": 13,
          "idFilm": 139245,
          "art": "Les",
          "titre": "Éternels",
          "titreVo": "Jianghu ernü",
          "titreNx": "江湖儿女",
          "realisateurs": "Jia Zhangke",
          "annee": 2018,
          "pays": "Chine-France",
          "duree": 141,
          "version": "VOSTF",
          "format": "DCP",
          "generique": [
            "Zhao Tao",
            "Liao Fan",
            "Xu Zheng",
            "Diao Yi'nan"
          ],
          "textes": [
            {
              "typeTexte": 1000,
              "texte": "Jamais une œuvre depuis Proust n'avait réussi à nous faire éprouver, comme _Les Éternels_, le temps qui passe. Les corps qui changent, les désirs qui meurent ou qui résistent, le monde qui se transforme. Et au milieu, l'amour immuable d'une femme pour un gangster. – É. L."
            }
          ]
        }
      ],
