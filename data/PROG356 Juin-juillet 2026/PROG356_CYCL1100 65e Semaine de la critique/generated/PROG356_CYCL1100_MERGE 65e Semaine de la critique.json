          "typeEvenement": 13,
          "idFilm": 155834,
          "titre": "City Of Owls",
          "realisateurs": "Zhenia Kazankina",
          "annee": 2026,
          "pays": "France-Allemagne-Italie",
          "duree": 13,
          "version": "VOSTF",
          "format": "DCP",
          "generique": [
            "Vera Engalycheva",
            "Lera Yacenko"
          ],
          "textes": [
            {
              "typeTexte": 1000,
              "texte": "Vera doit partir et couche sa petite sœur la veille au soir. Pour l'endormir, elle lui raconte l'histoire d'une ville engloutie par une nuit éternelle."
            }
          ]
        },
        {
          "idSeance": 217377,
          "ordre": 1,
          "dateHeure": "2026-06-08T18:30:00",
          "idSalle": [
            "GF",
            "Georges Franju"
          ],
