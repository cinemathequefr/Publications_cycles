          "titreVo": "",
          "realisateurs": "Jean Epstein",
          "annee": 1924,
          "pays": "France",
          "duree": 86,
          "version": "INT. FR.",
          "format": "35 mm",
          "ageMinimal": null,
          "generique": [
            "Nathalie Lissenko",
            "Genica Missirio",
            "Camille Bardou",
            "Sylviane de Castillo"
          ],
          "textes": [
            {
              "typeTexte": 9,
              "texte": "Le combat d'une mère brisée par la perte de son enfant dont l'image a été utilisée sur une affiche publicitaire qui envahit la ville."
            }
          ]
        },
        {
          "idSeance": 45751,
          "ordre": 1,
          "dateHeure": "2021-10-22T18:30:00",
          "idSalle": [
            "JE",
            "Jean Epstein"
          ],
          "idCategorie": 2395,
          "idEvenement": 23271,
          "typeEvenement": 13,
          "idFilm": 51482,
          "art": "La",
          "titre": "Riposte",
          "titreVo": "",
          "realisateurs": "Viatcheslav Tourjansky",
          "annee": 1922,
          "pays": "France",
          "duree": 74,
          "version": "INT. FR.",
          "format": "35 mm",
          "ageMinimal": null,
          "generique": [
            "Nathalie Lissenko",
            "Jean Angelo",
            "Bartkevitch"
          ],
          "textes": [
            {
              "typeTexte": 9,
              "texte": "Renvoyée d'un cirque où elle était écuyère, Alpha hérite d'un ticket de loterie qui va changer sa vie."
            }
          ]
        }
      ],
      "textes": [
        {
          "typeTexte": 8,
          "texte": "La célèbre société de production Albatros, créée par des russes blanc émigrés en France après la révolution de 1917, constituait une véritable troupe de réalisateurs, de comédiens, de techniciens. Avec près d'une quinzaine de films à son actif, l'actrice Nathalie Lissenko en était une figure de proue."
        }
      ]
