          "ageMinimal": null,
          "generique": [
            "Marilyne Canto",
            "Dominique Blanc",
            "Patrick Bruel",
            "Sergi López"
          ],
          "textes": [
            {
              "typeTexte": 9,
              "texte": "Un jour, Christelle est soudain prise de peur panique devant son bébé. Elle s'enfuit. Son mari, Laurent, la cherche partout, interrogeant père, mère, sœur, amis."
            }
          ]
        },
        {
          "idSeance": 47122,
          "ordre": 1,
          "dateHeure": "2021-09-27T21:15:00",
          "idSalle": [
            "JE",
            "Jean Epstein"
          ],
          "mention": "Séance présentée par Dominique Cabrera",
          "idCategorie": 2510,
          "idEvenement": 24606,
          "typeEvenement": 13,
          "idFilm": 40327,
          "art": "Les",
          "titre": "Longs adieux",
          "titreVo": "Dolguie provody = Dolgie provody",
          "realisateurs": "Kira Mouratova",
          "annee": 1971,
          "pays": "URSS",
          "ageMinimal": null,
          "generique": [
            "Zinaïda Charko",
            "Oleg Vladimirski",
            "Youri Kaiourov"
          ],
          "textes": []
        }
      ],
      "textes": [
        {
          "typeTexte": 8,
          "texte": "En écho à la rétrospective de ses films documentaires qui s'est tenue en mai dernier à la Cinémathèque du documentaire, retour sur le versant fiction de l'œuvre de la cinéaste avec l'un de ses plus beaux films. Pour sa carte blanche, Dominique Cabrera a choisi un film intimiste et passionnant, _Les Longs Adieux d_e Kira Mouratova_._"
        }
      ]
    },
