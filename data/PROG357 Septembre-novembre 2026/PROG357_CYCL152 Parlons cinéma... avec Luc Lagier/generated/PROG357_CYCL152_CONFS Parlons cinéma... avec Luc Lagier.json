    "mentionAnimation": "Animé par Isaac Gaido-Daniel"
  },
  {
    "idCategorie": 3111,
    "idEvenement": 36326,
    "titre": "Dialogue avec Édouard Louis",
    "duree": 75,
    "idTypeConference": 16,
    "typeConference": "Dialogue",
    "textes": [
      {
        "typeTexte": 9,
        "texte": "C'est le film des frères Dardenne le plus inventif du point de vue formel. C'est l'immense Marion Cotillard qui répète la même scène encore et encore, et nous bouleverse : elle supplie ses collègues de la sauver d'un plan de licenciement à l'usine qui lui ferait tout perdre. – Édouard Louis"
      }
    ],
    "intervenants": [
      {
        "nomComplet": "Édouard Louis",
        "idFonction": 142,
        "fonction": "Interviewé",
        "ordre": 1
      },
      {
        "nomComplet": "Isaac Gaido-Daniel",
