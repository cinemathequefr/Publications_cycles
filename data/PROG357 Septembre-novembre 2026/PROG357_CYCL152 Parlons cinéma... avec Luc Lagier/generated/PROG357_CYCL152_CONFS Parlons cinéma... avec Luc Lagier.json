    ],
    "mentionAnimation": "Animé par Isaac Gaido-Daniel"
  },
  {
    "idCategorie": 3111,
    "idEvenement": 36327,
    "titre": "Dialogue avec Édouard Louis",
    "duree": 75,
    "idTypeConference": 16,
    "typeConference": "Dialogue",
    "textes": [
      {
        "typeTexte": 9,
        "texte": "Jamais une œuvre depuis Proust n'avait réussi à nous faire éprouver, comme _Les Éternels_, le temps qui passe. Les corps qui changent, les désirs qui meurent ou qui résistent, le monde qui se transforme. Et au milieu, l'amour immuable d'une femme pour un gangster. – Édouard Louis"
      }
    ],
