          "idFilm": 155604,
          "titre": "West Beyrouth (bande-annonce)",
          "realisateurs": "Anonyme",
          "annee": 1998,
          "pays": "France-Liban-Belgique-Norvège",
          "duree": 2,
          "version": "VO",
          "format": "35 mm",
          "textes": []
