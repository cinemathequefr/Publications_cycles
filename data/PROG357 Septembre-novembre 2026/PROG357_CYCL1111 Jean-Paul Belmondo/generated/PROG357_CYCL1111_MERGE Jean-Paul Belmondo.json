          "typeEvenement": 13,
          "idFilm": 51129,
          "titre": "Classe tous risques",
          "realisateurs": "Claude Sautet",
          "annee": 1960,
          "pays": "France-Italie",
          "duree": 110,
          "version": "",
          "format": "DCP",
          "restauration": true,
          "generique": [
            "Lino Ventura",
            "Jean-Paul Belmondo",
            "Sandra Milo",
            "Marcel Dalio"
          ],
          "adaptation": "D'après le roman _Classe tous risques_ de José Giovanni.",
          "textes": [
            {
              "typeTexte": 1000,
              "texte": "À Milan, un gangster, bon père de famille, tente de regagner Paris avec l'aide d'un protecteur désigné, alors qu'une condamnation à mort pèse sur lui. Les débuts de Claude Sautet, marqués par la veine noire américaine, constituent l'un des moments forts du cinéma français des années 60, en plein avènement de la Nouvelle Vague."
            }
          ]
        },
