          "idCategorie": 4206,
          "idEvenement": 36618,
          "typeEvenement": 13,
          "idFilm": 48837,
          "titre": "À bout de souffle",
          "realisateurs": "Jean-Luc Godard",
          "annee": 1960,
          "pays": "France",
          "duree": 90,
          "version": "",
          "format": "DCP",
          "restauration": true,
          "generique": [
            "Jean-Paul Belmondo",
            "Jean Seberg",
            "Henri-Jacques Huet",
            "Jean-Pierre Melville"
          ],
          "textes": [
            {
              "typeTexte": 1000,
              "texte": "En 1960, Jean-Luc Godard rend un hommage effronté aux séries B américaines. Histoire policière débridée au style désinvolte, interprétée par de jeunes stars effervescentes, _À bout de souffle_ lance la Nouvelle Vague et redéfinit les codes du cinéma moderne."
            }
          ]
        }
