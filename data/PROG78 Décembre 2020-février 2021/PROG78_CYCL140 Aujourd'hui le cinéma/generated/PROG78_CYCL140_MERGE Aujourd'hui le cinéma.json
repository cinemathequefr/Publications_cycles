          "ageMinimal": null,
          "textes": [
            {
              "typeTexte": 9,
              "texte": "En plein désert algérien, dans son relais, une femme écrit son histoire. Elle accueille, pour une cigarette, un café ou des œufs, des routiers, des êtres en errance et des rêves... Elle s'appelle Malika."
            },
            {
              "typeTexte": 99,
              "texte": "Avant-première avec Météore Films. Retrouvez le film en salles à partir du 16 décembre."
            }
          ]
        }
      ],
      "textes": []
    },
    {
      "titreSousCycle": "Prix Gérard Frot-Coutaz / Festival Entrevues Belfort",
      "tri": 4,
      "items": [
        {
          "idSeance": 36356,
          "ordre": 1,
